{
  "name": "finno",
  "version": "0.1.0",
  "private": true,
  "repository": {
    "url": "git@github.com:AlexandreOliver/finno.git"
  },
  "scripts": {
    "dev": "pnpm service:db:up && pnpm wait-for-database && pnpm run db:migrate && next dev",
    "test": " pnpm service:db:up && pnpm wait-for-database && concurrently --names n,j --hide n --kill-others --success command-jest 'next dev' 'jest --runInBand' ",
    "test:watch": "jest --runInBand --watch",
    "build": "next build",
    "lint": "eslint",
    "service:db:up": "docker compose -f infra/compose.yaml up -d",
    "service:db:down": "docker compose -f infra/compose.yaml down",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "pnpm service:db:up && drizzle-kit studio",
    "db:seed": "node -r esbuild-register infra/database/seed.ts",
    "wait-for-database": "node infra/scripts/wait-for-database.js"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "async-retry": "^1.3.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.8.0",
    "next": "16.2.4",
    "pg": "^8.20.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.4.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "uuidv7": "^1.2.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@jest/globals": "^30.3.0",
    "@tailwindcss/postcss": "^4",
    "@types/async-retry": "^1.4.9",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "dotenv": "^17.4.2",
    "esbuild-register": "^3.6.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "jest": "^30.3.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
