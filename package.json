{
  "name": "finno",
  "version": "0.1.0",
  "private": true,
  "repository": {
    "url": "git@github.com:AlexandreOliver/finno.git"
  },
  "scripts": {
    "dev": "pnpm service:db:up && pnpm wait-for-database && pnpm run db:push && pnpm db:seed && next dev",
    "dev:web": "next dev",
    "test": "pnpm service:db:up && pnpm wait-for-database && concurrently --names n,j --hide n --kill-others --success command-jest 'next dev' 'jest --runInBand' ",
    "test:watch": "jest --runInBand --watch",
    "build": "next build && pnpm db:push && pnpm db:seed",
    "lint": "eslint",
    "service:db:up": "docker compose -f src/infrastructure/compose.yaml up -d",
    "service:db:down": "docker compose -f src/infrastructure/compose.yaml down",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "pnpm service:db:up && drizzle-kit studio",
    "db:seed": "node -r esbuild-register src/infrastructure/scripts/seed.ts",
    "db:view": "drizzle-lab visualizer",
    "wait-for-database": "node src/infrastructure/scripts/wait-for-database.js",
    "commit": "cz",
    "prepare": "husky"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@lukemorales/query-key-factory": "^1.3.4",
    "@tanstack/react-query": "^5.100.13",
    "@tanstack/react-query-devtools": "5.100.13",
    "@teispace/next-themes": "^0.5.0",
    "async-retry": "^1.3.3",
    "bcrypt": "^6.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "drizzle-zod": "^0.8.3",
    "lucide-react": "^1.8.0",
    "next": "16.2.4",
    "pg": "^8.20.0",
    "react": "19.2.4",
    "react-day-picker": "^9.14.0",
    "react-dom": "19.2.4",
    "recharts": "3.8.0",
    "server-only": "^0.0.1",
    "shadcn": "^4.6.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "uuid": "^14.0.0",
    "vaul": "^1.1.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@jest/globals": "^30.3.0",
    "@tailwindcss/postcss": "^4",
    "@tanstack/eslint-plugin-query": "^5.100.13",
    "@types/async-retry": "^1.4.9",
    "@types/bcrypt": "^6.0.0",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "cz-conventional-changelog": "^3.3.0",
    "dotenv": "^17.4.2",
    "drizzle-lab": "^0.11.0",
    "esbuild-register": "^3.6.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  }
}
